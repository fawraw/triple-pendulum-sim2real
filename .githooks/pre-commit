#!/usr/bin/env bash
# Pre-commit hook for triple-pendulum-sim2real.
#
# Two-layer defense:
#   1. Block credential-bearing file paths (always run, project-specific).
#   2. Delegate secret-content scanning to the Lab Perso global hook if
#      present (it has context-aware DOC_MARKERS filtering and avoids the
#      circular problem where pattern definitions match themselves).
#
# Activate with:  git config core.hooksPath .githooks
# Bypass:         git commit --no-verify

set -euo pipefail

# ---- 1. Reject credential-bearing paths ----
staged=$(git diff --cached --name-only --diff-filter=AM)
if [ -n "$staged" ]; then
    banned_paths_re='(^\.env$|^\.env\.|/\.env$|^credentials/|\.pem$|\.p12$|id_rsa$|id_ed25519$)'
    forbidden=$(echo "$staged" | grep -E "$banned_paths_re" || true)
    if [ -n "$forbidden" ]; then
        echo "ERROR pre-commit: refusing to commit credential-bearing files:"
        echo "$forbidden" | sed 's/^/  /'
        echo ""
        echo "Move them outside the repo or .gitignore the path."
        exit 1
    fi
fi

# ---- 2. Scan staged content for secret-like literals ----
# Inlined (was previously delegated to $HOME/.git-hooks/pre-commit, which does
# not exist on every clone -- so the scan silently never ran). Only the added
# lines of staged files are scanned. Placeholders (YOUR_*, <...>, example) are
# ignored so the n8n template JSONs do not trip it.
added=$(git diff --cached --no-color -U0 --diff-filter=AM 2>/dev/null \
        | grep '^+' | grep -v '^+++' || true)
if [ -n "$added" ]; then
    # Telegram bot token | RunPod key | PEM private key block | AWS access key |
    # *_SECRET/_TOKEN/_PASSWORD = "literal".
    secret_re='([0-9]{8,10}:[A-Za-z0-9_-]{35})|(rpa_[A-Za-z0-9]{20,})|(-----BEGIN [A-Z ]*PRIVATE KEY-----)|(AKIA[0-9A-Z]{16})|((SECRET|TOKEN|PASSWORD|API_KEY)["'\'' ]*[:=]["'\'' ]*[A-Za-z0-9/_+-]{12,})'
    hits=$(printf '%s\n' "$added" \
           | grep -nEi "$secret_re" \
           | grep -vEi 'YOUR_|<[a-z_]+>|placeholder|example|os\.environ|getenv|\$\{?env' || true)
    if [ -n "$hits" ]; then
        echo "ERROR pre-commit: staged content looks like it contains a secret:"
        echo "$hits" | sed 's/^/  /'
        echo ""
        echo "Move it to an env var / out-of-repo file, or commit with --no-verify if it is a false positive."
        exit 1
    fi
fi

# ---- 3. Also delegate to the global Lab Perso hook if present ----
GLOBAL_HOOK="$HOME/.git-hooks/pre-commit"
if [ -x "$GLOBAL_HOOK" ] && [ "$GLOBAL_HOOK" != "$0" ]; then
    "$GLOBAL_HOOK" "$@"
    exit $?
fi

echo "pre-commit OK (project layer)"
exit 0
